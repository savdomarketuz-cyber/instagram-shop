# Firebase Configuration (Client-safe)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_auth_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_storage_bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_key

# Yandex Cloud S3 (Server-side ONLY — NEVER use NEXT_PUBLIC_ prefix for secrets!)
YANDEX_S3_ACCESS_KEY=your_access_key
YANDEX_S3_SECRET_KEY=your_secret_key
YANDEX_S3_BUCKET=savdomarketimag
YANDEX_S3_REGION=ru-central1

# Yandex Maps (Client-safe)
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=your_maps_key

# Admin Authentication (Server-side ONLY)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=your_secure_password_here
ADMIN_SECRET=your_random_secret_here

# AI API Keys (Server-side ONLY)
GROQ_API_KEY_1=your_groq_api_key
GROQ_API_KEY_2=your_backup_groq_api_key

