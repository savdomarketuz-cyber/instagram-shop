# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_auth_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_storage_bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Yandex Cloud S3 (Object Storage)
# IMPORTANT: These are server-side only in a real app, but for Next.js 
# client uploading, they need NEXT_PUBLIC prefix.
NEXT_PUBLIC_YANDEX_ACCESS_KEY=your_access_key
NEXT_PUBLIC_YANDEX_SECRET_KEY=your_secret_key
NEXT_PUBLIC_YANDEX_BUCKET=savdomarketimag
NEXT_PUBLIC_YANDEX_REGION=ru-central1
NEXT_PUBLIC_YANDEX_ENDPOINT=https://storage.yandexcloud.net

# API Keys
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=your_maps_key
